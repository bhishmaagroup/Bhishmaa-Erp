# Bhishmaa ERP Client Configuration

# Mode: false for local SQLite client
IS_ONLINE=false

# Connection URL to your remote PostgreSQL database
# IMPORTANT: Replace <SERVER_PUBLIC_IP> with your server's actual public IP address or domain name!
# (For example, if your server's public IP is 15.206.120.45, write database address as 15.206.120.45:5432)
DATABASE_URL=postgresql://enoughsudhanshu:awadhnath@<SERVER_PUBLIC_IP>:5432/erpdb

# Security Key for encryption (Must match your server's SECRET_KEY!)
SECRET_KEY=bhishmaa-super-secret-key
