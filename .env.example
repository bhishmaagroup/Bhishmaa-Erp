# ============================================================
# BHISHMAA ERP — ENVIRONMENT CONFIGURATION
# Rename this file to .env and fill in your values
# ============================================================

# --- MODE ---
# OFFLINE client pe: IS_ONLINE=false
# Cloud server pe: IS_ONLINE=true
IS_ONLINE=false

# --- DATABASE ---
# Remote PostgreSQL URL (REQUIRED on offline client for sync!)
# Format: postgresql://user:password@host:5432/database_name
DATABASE_URL=postgresql://bhishmaa_user:your_password@your-server.com:5432/bhishmaa_db

# --- SYNC CONFIG ---
# Background sync interval in seconds (default: 120 = 2 minutes)
SYNC_INTERVAL_SECONDS=120

# Cloud server REST API URL (only if using REST sync mode, not direct DB)
SYNC_SERVER_URL=http://your-cloud-server.com

# Auth token for REST sync (must match server SECRET_KEY)
CLOUD_SYNC_TOKEN=your-secret-token-here

# --- APP ---
SECRET_KEY=change-this-to-a-long-random-string

# --- EMAIL (optional) ---
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
